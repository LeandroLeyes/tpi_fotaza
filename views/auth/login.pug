extends layout

block content

  .auth-container

    .auth-card

      .text-center.mb-4

        img(src="/images/fotaza-logo-1.png" width = "50px")

        h2.mt-3
          | Bienvenido

        p.text-muted
          | Inicia sesión en Fotaza


      form(action="/auth/login", method="post")

        .mb-3

          input.form-control.auth-input(type="email", name="email", placeholder="Correo electrónico")

        .mb-4

          input.form-control.auth-input(type="password", name="password", placeholder="Contraseña")

        button.btn.auth-btn.w-100(type="submit")
          | Iniciar sesión


      .text-center.mt-4

        span.text-muted
          | ¿No tienes cuenta?

        a.ms-2.auth-link(href="/auth/register")
          | Regístrate