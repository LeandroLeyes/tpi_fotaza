extends layout

block content
  h2 Iniciar Sesión

  form(method="POST", action="/login")
    .mb-3
      label.form-label Email
      input.form-control(type="email", name="email", required)

    .mb-3
      label.form-label Contraseña
      input.form-control(type="password", name="password", required)

    button.btn.btn-primary(type="submit") Ingresar

  p.mt-3
    | ¿No tenés cuenta? 
    a(href="/register") Registrate acá