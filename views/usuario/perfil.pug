extends layout

block content

    .container-fluid.mt-4

        .card.shadow-sm.mb-4.profile-card

            .card-body

                .profile-header

                    .profile-avatar

                        img.rounded-circle(
                            src=usuarioPerfil.avatar || "/images/Patroclo.jpeg"
                        )

                    .profile-info

                        h2.mb-2= usuarioPerfil.username

                        p.text-muted.mb-3= usuarioPerfil.email

                        .profile-stats

                            .stat
                                h4= cantidadPublicaciones
                                span Publicaciones

                            .stat
                                h4= cantidadSeguidores
                                span Seguidores

                            .stat
                                h4= cantidadSeguidos
                                span Siguiendo

                        if esMiPerfil

                            a.btn.btn-outline-success(
                                href="/usuario/perfil/editar"
                            )
                                | Editar perfil

                        else

                            if siguiendo

                                form(
                                    action=`/usuario/dejar-seguir/${usuarioPerfil.id}`,
                                    method="POST"
                                )

                                    button.btn.btn-outline-danger(
                                        type="submit"
                                    )
                                        | Dejar de seguir

                            else

                                form(
                                    action=`/usuario/seguir/${usuarioPerfil.id}`,
                                    method="POST"
                                )

                                    button.btn.btn-success(
                                        type="submit"
                                    )
                                        | Seguir

        h4.mb-4 Publicaciones

        include ../partials/publicGrid