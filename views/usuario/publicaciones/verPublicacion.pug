extends ../layout

block content

    .container-fluid.mt-4

        .row.g-4

            .col-lg-8

                .card.shadow-sm.border-0

                    if publicacion.imagenes.length > 0

                        #carouselPublicacion.carousel.slide(data-bs-ride="false")

                            .carousel-inner

                                each imagen, index in publicacion.imagenes

                                    .carousel-item(class=index === 0 ? "active" : "")

                                        img.d-block.w-100.rounded(
                                            src=imagen.imagenBase64,
                                            alt=publicacion.titulo
                                        )

                            if publicacion.imagenes.length > 1

                                button.carousel-control-prev(
                                    type="button",
                                    data-bs-target="#carouselPublicacion",
                                    data-bs-slide="prev"
                                )
                                    span.carousel-control-prev-icon

                                button.carousel-control-next(
                                    type="button",
                                    data-bs-target="#carouselPublicacion",
                                    data-bs-slide="next"
                                )
                                    span.carousel-control-next-icon

                        if publicacion.imagenes.length > 1

                            .text-center.py-2.text-muted.small

                                span#indicadorImagen Imagen 1 de #{publicacion.imagenes.length}

            .col-lg-4

                .card.shadow-sm.border-0.h-100

                    .card-body

                        .d-flex.justify-content-between.align-items-start.mb-3

                            h2.card-title.mb-0= publicacion.titulo

                            .dropdown

                                button.btn.btn-light.btn-sm(
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                ) ⋮

                                ul.dropdown-menu.dropdown-menu-end

                                    if esPropietario

                                        li

                                            form(
                                                action=`/usuario/publicaciones/${publicacion.id}/comentarios`
                                                method="POST"
                                            )

                                                if publicacion.comentariosActivo

                                                    button.dropdown-item(type="submit")
                                                        | Cerrar comentarios

                                                else

                                                    button.dropdown-item(type="submit")
                                                        | Abrir comentarios

                                    else

                                        li

                                            a.dropdown-item(
                                                href=`/usuario/publicaciones/${publicacion.id}/denunciar`
                                            )
                                                | Denunciar publicación

                        p.text-muted.mb-3= publicacion.descripcion

                        if publicacion.Etiqueta && publicacion.Etiqueta.length

                            .publication-tags.mb-4

                                each etiqueta in publicacion.Etiqueta

                                    a.text-decoration-none.me-2(
                                        href=`/buscar?q=${etiqueta.nombre}`
                                    )
                                        | ##{etiqueta.nombre}

                        hr

                        a.text-decoration-none.text-dark(
                            href=`/usuario/perfil/${publicacion.Usuario.id}`
                        )

                            .d-flex.align-items-center.gap-3

                                img.rounded-circle.shadow-sm(
                                    src=publicacion.Usuario.avatar || "/images/Patroclo.jpeg"
                                    width="55"
                                    height="55"
                                    style="object-fit:cover"
                                )

                                div

                                    h6.mb-0= publicacion.Usuario.username

                                    small.text-muted Ver perfil

                        hr

                        each imagen, index in publicacion.imagenes

                            .imagen-panel(
                                id=`panel-imagen-${index}`,
                                style=index === 0 ? "" : "display:none"
                            )

                                if !esPropietario

                                    h5.mb-3 Valoración

                                    form(
                                        action=`/usuario/valoraciones/${imagen.id}`
                                        method="POST"
                                        novalidate
                                    )

                                        input(
                                            type="hidden"
                                            name="publicacionId"
                                            value=publicacion.id
                                        )

                                        .rating-container.mb-3

                                            - for (let i = 1; i <= 5; i++)
                                                button.btn.btn-link.p-0.fs-3.star-btn(
                                                    type="submit"
                                                    name="puntaje"
                                                    value=`${i}`
                                                    class=imagen.Valoracions && imagen.Valoracions.find(v => v.UsuarioId === miUsuarioId && v.puntaje === i) ? 'star-active' : ''
                                                ) ★

                                    hr

                                h5.mb-3 Estadísticas

                                .row.text-center.mb-4

                                    .col-6

                                        .card.bg-light.border-0

                                            .card-body.py-3

                                                - const total = imagen.Valoracions ? imagen.Valoracions.length : 0
                                                - const promedio = total > 0 ? (imagen.Valoracions.reduce((s, v) => s + v.puntaje, 0) / total) : 0

                                                h4.mb-0.text-success= promedio.toFixed(1)

                                                small.text-muted Promedio

                                    .col-6

                                        .card.bg-light.border-0

                                            .card-body.py-3

                                                h4.mb-0.text-success= total

                                                small.text-muted Valoraciones

                                hr

                                h5.mb-2 Comentarios

                                if publicacion.comentariosActivo

                                    form.mb-3(
                                        action=`/usuario/comentarios/${imagen.id}`
                                        method="POST"
                                        novalidate
                                    )

                                        input(
                                            type="hidden"
                                            name="publicacionId"
                                            value=publicacion.id
                                        )

                                        textarea.form-control.mb-2(
                                            name="contenido"
                                            rows="3"
                                            placeholder="Escribí un comentario..."
                                        )

                                        button.btn.btn-success(type="submit") Comentar

                                else

                                    .alert.alert-secondary.mb-3
                                        | Los comentarios fueron cerrados por el autor.

                                if imagen.Comentarios && imagen.Comentarios.length

                                    button.btn.btn-outline-success.w-100.mb-3(
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target=`#comentarios-${index}`
                                        aria-expanded="true"
                                    )
                                        | Comentarios (#{imagen.Comentarios.length})

                                    .collapse.show(id=`comentarios-${index}`)

                                        .comment-container

                                            each comentario in imagen.Comentarios

                                                .card.bg-light.border-0.mb-3

                                                    .card-body

                                                        .d-flex.align-items-center.gap-2.mb-2

                                                            img.rounded-circle(
                                                                src=comentario.Usuario.avatar || "/images/Patroclo.jpeg"
                                                                width="35"
                                                                height="35"
                                                                style="object-fit:cover"
                                                            )

                                                            strong= comentario.Usuario.username

                                                        p.mb-0= comentario.contenido

                                else

                                    p.text-muted.small No hay comentarios en esta imagen.

    script.

        const carousel = document.getElementById('carouselPublicacion');
        const indicador = document.getElementById('indicadorImagen');
        const totalImagenes = #{publicacion.imagenes.length};

        if (carousel) {
            carousel.addEventListener('slide.bs.carousel', function (e) {
                const siguiente = e.to;

                document.querySelectorAll('.imagen-panel').forEach(function(panel) {
                    panel.style.display = 'none';
                });

                const panelActivo = document.getElementById('panel-imagen-' + siguiente);
                if (panelActivo) panelActivo.style.display = '';

                if (indicador) {
                    indicador.textContent = 'Imagen ' + (siguiente + 1) + ' de ' + totalImagenes;
                }
            });
        }
