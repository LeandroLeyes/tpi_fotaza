extends ../layout

block content

    .container-fluid.mt-4

        .row.g-4

            .col-lg-8

                .card.shadow-sm.border-0

                    if publicacion.imagenes.length > 0

                        #carouselPublicacion.carousel.slide(data-bs-ride="false")

                            .carousel-inner

                                each imagen, index in publicacion.imagenes

                                    .carousel-item(
                                        class=index === 0 ? "active" : ""
                                    )

                                        img.d-block.w-100.rounded(
                                            src=imagen.imagenBase64,
                                            alt=publicacion.titulo
                                        )

                            if publicacion.imagenes.length > 1

                                button.carousel-control-prev(
                                    type="button",
                                    data-bs-target="#carouselPublicacion",
                                    data-bs-slide="prev"
                                )

                                    span.carousel-control-prev-icon

                                button.carousel-control-next(
                                    type="button",
                                    data-bs-target="#carouselPublicacion",
                                    data-bs-slide="next"
                                )

                                    span.carousel-control-next-icon

            .col-lg-4

                .card.shadow-sm.border-0.h-100

                    .card-body

                        .d-flex.justify-content-between.align-items-start.mb-3

                            h2.card-title.mb-0
                                = publicacion.titulo

                            .dropdown

                                button.btn.btn-light.btn-sm(
                                    type="button"
                                    data-bs-toggle="dropdown"
                                    aria-expanded="false"
                                )
                                    | ⋮

                                ul.dropdown-menu.dropdown-menu-end

                                    if esPropietario

                                        li

                                            form(
                                                action=`/usuario/publicaciones/${publicacion.id}/comentarios`
                                                method="POST"
                                            )

                                                if publicacion.comentariosActivo

                                                    button.dropdown-item(
                                                        type="submit"
                                                    )
                                                        | Cerrar comentarios

                                                else

                                                    button.dropdown-item(
                                                        type="submit"
                                                    )
                                                        | Abrir comentarios

                                    else

                                        li

                                            a.dropdown-item(
                                                href=`/usuario/publicaciones/${publicacion.id}/denunciar`
                                            )
                                                | Denunciar publicación

                        p.text-muted.mb-3= publicacion.descripcion

                        if publicacion.Etiqueta && publicacion.Etiqueta.length

                            .publication-tags.mb-4

                                each etiqueta in publicacion.Etiqueta

                                    a.text-decoration-none.me-2(
                                        href=`/buscar?q=${etiqueta.nombre}`
                                    )
                                        | ##{etiqueta.nombre}

                        hr

                        a.text-decoration-none.text-dark(
                            href=`/usuario/perfil/${publicacion.Usuario.id}`
                        )

                            .d-flex.align-items-center.gap-3

                                img.rounded-circle.shadow-sm(
                                    src=publicacion.Usuario.avatar || "/images/Patroclo.jpeg"
                                    width="55"
                                    height="55"
                                )

                                div

                                    h6.mb-0
                                        = publicacion.Usuario.username

                                    small.text-muted
                                        | Ver perfil

                        hr

                        if !esPropietario

                            h5.mb-3 Valoración

                            form(
                                action=`/usuario/valoraciones/${publicacion.imagenes[0].id}`
                                method="POST"
                                novalidate
                            )

                                input(
                                    type="hidden"
                                    name="publicacionId"
                                    value=publicacion.id
                                )

                                .d-flex.align-items-center.gap-1.mb-3

                                    button.btn.btn-link.p-0.fs-3(
                                        type="submit"
                                        name="puntaje"
                                        value="1"
                                    ) ★

                                    button.btn.btn-link.p-0.fs-3(
                                        type="submit"
                                        name="puntaje"
                                        value="2"
                                    ) ★

                                    button.btn.btn-link.p-0.fs-3(
                                        type="submit"
                                        name="puntaje"
                                        value="3"
                                    ) ★

                                    button.btn.btn-link.p-0.fs-3(
                                        type="submit"
                                        name="puntaje"
                                        value="4"
                                    ) ★

                                    button.btn.btn-link.p-0.fs-3(
                                        type="submit"
                                        name="puntaje"
                                        value="5"
                                    ) ★

                            hr

                        h5.mb-3 Estadísticas

                        .row.text-center.mb-4

                            .col-6

                                .card.bg-light.border-0

                                    .card-body.py-3

                                        h4.mb-0.text-success
                                            = promedioValoraciones.toFixed(1)

                                        small.text-muted
                                            | Promedio

                            .col-6

                                .card.bg-light.border-0

                                    .card-body.py-3

                                        h4.mb-0.text-success
                                            = cantidadValoraciones

                                        small.text-muted
                                            | Valoraciones

                        hr

                        h5.mb-3| Comentarios

                        if publicacion.comentariosActivo

                            form(
                                action=`/usuario/comentarios/${publicacion.imagenes[0].id}`
                                method="POST"
                                novalidate
                            )

                                input(
                                    type="hidden"
                                    name="publicacionId"
                                    value=publicacion.id
                                )

                                textarea.form-control.mb-3(
                                    name="contenido"
                                    rows="3"
                                    placeholder="Escribe un comentario..."
                                )

                                button.btn.btn-success(
                                    type="submit"
                                )
                                    | Comentar

                        else

                            .alert.alert-secondary
                                | Los comentarios fueron cerrados por el autor.

                        hr

                        if publicacion.imagenes[0].Comentarios

                            button.btn.btn-outline-success.w-100.mb-3(
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#comentariosCollapse"
                                aria-expanded="true"
                            )
                                | Comentarios (#{publicacion.imagenes[0].Comentarios.length})

                            .collapse.show#comentariosCollapse

                                .comment-container

                                    if publicacion.imagenes[0].Comentarios.length

                                        each comentario in publicacion.imagenes[0].Comentarios

                                            .card.bg-light.border-0.mb-3

                                                .card-body

                                                    .d-flex.align-items-center.gap-2.mb-2

                                                        img.rounded-circle(
                                                            src=comentario.Usuario.avatar || "/images/Patroclo.jpeg"
                                                            width="35"
                                                            height="35"
                                                        )

                                                        strong
                                                            = comentario.Usuario.username

                                                    p.mb-0
                                                        = comentario.contenido

                                    else

                                        p.text-muted
                                            | No hay comentarios todavía.