extends layout

block content

    .container.mt-5

        .row.justify-content-center

            .col-lg-8

                .card.shadow-sm.border-0

                    .card-header.bg-white

                        h3.mb-0
                            | Editar Perfil

                    .card-body

                        form(
                            action="/usuario/perfil/editar"
                            method="POST"
                            enctype="multipart/form-data"
                        )

                            .text-center.mb-4

                                if usuario.avatar

                                    img.rounded-circle.shadow(
                                        src=usuario.avatar
                                        width="150"
                                        height="150"
                                        style="object-fit: cover;"
                                    )

                                else

                                    img.rounded-circle.shadow(
                                        src="/images/Patroclo.jpeg"
                                        width="150"
                                        height="150"
                                        style="object-fit: cover;"
                                    )

                            .mb-4

                                label.form-label
                                    | Avatar

                                input.form-control(
                                    type="file"
                                    name="avatar"
                                    accept="image/*"
                                )

                                .form-check.mt-2

                                    input.form-check-input(
                                        type="checkbox"
                                        name="eliminarAvatar"
                                        value="true"
                                        id="eliminarAvatar"
                                    )

                                    label.form-check-label(
                                        for="eliminarAvatar"
                                    )
                                        | Eliminar avatar actual

                            .row

                                .col-md-6.mb-3

                                    label.form-label
                                        | Nombre

                                    input.form-control(
                                        type="text"
                                        name="name"
                                        value=usuario.name
                                        required
                                    )

                                .col-md-6.mb-3

                                    label.form-label
                                        | Apellido

                                    input.form-control(
                                        type="text"
                                        name="lastName"
                                        value=usuario.lastName
                                        required
                                    )

                            .mb-3

                                label.form-label
                                    | Nombre de usuario

                                input.form-control(
                                    type="text"
                                    name="username"
                                    value=usuario.username
                                    required
                                )

                            .mb-3

                                label.form-label
                                    | Correo electrónico

                                input.form-control(
                                    type="email"
                                    name="email"
                                    value=usuario.email
                                    required
                                )

                            .mb-4

                                label.form-label
                                    | Biografía

                                textarea.form-control(
                                    name="bio"
                                    rows="5"
                                    placeholder="Cuéntale algo a la comunidad sobre ti..."
                                )= usuario.bio

                            .d-grid

                                button.btn.btn-success.btn-lg(
                                    type="submit"
                                )
                                    | Guardar cambios